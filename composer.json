{
    "config": {
        "process-timeout": 0
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": ["app/Helpers.php"]
    },
    "require": {
        "gotzmann/comet": "^2.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "scripts": {
        "db:start": "docker-compose up -d",
        "db:stop": "docker-compose down",
        "dev": "php index.php start",
        "dev:stop": "lsof -ti:8080 | xargs kill -9 2>/dev/null || true"
    }
}
